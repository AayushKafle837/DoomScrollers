{
  "manifest_version": 3,
  "name": "Webpage Censorship",
  "version": "1.0",
  "description": "Detects unsafe content and notifies parents via email",

  "action": {
    "default_popup": "popup/popup.html"
  },

  "icons": {
    "128": "images/icon-128.png"
  },

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "permissions": [
    "storage",
    "tabs"
  ],

  "host_permissions": [
    "https://api.emailjs.com/*"
  ]
}
